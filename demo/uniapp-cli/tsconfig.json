{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "types": [
      "@dcloudio/types",
      "@wot-ui/ui/global"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "*.ts",
    "shims-vue.d.ts"
  ],
  "exclude": [
    "vite.config.ts"
  ]
}
