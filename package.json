{
  "name": "vue3-transfer",
  "version": "0.0.1",
  "description": "Transfer Vue 3 SFC source to plain JavaScript in the browser",
  "type": "module",
  "main": "./dist/vue3-transfer.js",
  "module": "./dist/vue3-transfer.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vue3-transfer.js",
      "types": "./dist/types/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/types/react.d.ts"
    },
    "./uniapp": {
      "import": "./dist/uniapp.js",
      "types": "./dist/types/uniapp.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "build:vendor": "vite build --config demo/vendor-src/vue/vite.config.ts",
    "build:vendor-react": "vite build --config demo/vendor-src/react/vite.config.ts",
    "build:vendor-uniapp": "vite build --config demo/vendor-src/uniapp/vite.config.ts",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "vue3",
    "compiler",
    "sfc",
    "transfer",
    "rolldown",
    "vite",
    "browser",
    "vapor"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@babel/standalone": "^8.0.2",
    "@vue/compiler-sfc": "3.6.0-beta.15"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.31",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@wot-ui/ui": "^2.1.0",
    "antd": "^6.4.4",
    "element-plus": "2.14.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sass": "^1.101.0",
    "styled-components": "^6.4.2",
    "typescript": "^5.8.0",
    "vite": "^8.0.16",
    "vue": "3.6.0-beta.15"
  }
}
